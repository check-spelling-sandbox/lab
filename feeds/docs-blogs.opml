  <outline text="Instruction Manuel"
           title="Instruction Manuel"
           xmlUrl="https://instructionmanuel.com/rss.xml"
           type="rss"
           htmlUrl="https://instructionmanuel.com"
           description="New blog from Manny Silva, technical writer, engineer, maintainer of the popular open-source docs testing tool https://docs.doc-detective.com[Doc Detective], and author of the book https://instructionmanuel.com/books/docs-as-tests[_Docs as Tests_].">
  </outline>
  
  <outline text="James Tasse"
           title="James Tasse"
           xmlUrl="https://jamestasse.tech/rss.xml"
