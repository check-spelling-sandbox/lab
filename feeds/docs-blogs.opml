           xmlUrl="https://cybertext.wordpress.com/feed"
           type="rss"
           htmlUrl="https://cybertext.wordpress.com"
           description="Long-running newsletter and blog from CyberText Consulting offering practical advice on documentation tools (e.g. Word, Flare), career development, and web communication for technical writers.">
  </outline>
  
  <outline text="Dachary Carey"
           title="Dachary Carey"
           xmlUrl="https://dacharycarey.com/index.xml"
           type="atom"
           htmlUrl="https://dacharycarey.com"
           description="Personal blog of Dachary Carey, a technical writer and software developer.Posts cover a range of topics including documentation audits, case studies of docs sites/architecture, AI in technical writing, and programming docs tools.">
  </outline>
  
  <outline text="Damilola Oladele"
           title="Damilola Oladele"
