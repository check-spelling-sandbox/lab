  </outline>
  
  <outline text="Heroic Technical Writing"
           title="Heroic Technical Writing"
           xmlUrl="https://heroictechwriting.com/feed"
           type="rss"
           htmlUrl="https://heroictechwriting.com"
           description="Bart Leahy’s blog providing advice and insights on the business and personal aspects of technical communication, including career growth, professional development, and proposal writing.">
  </outline>
  
