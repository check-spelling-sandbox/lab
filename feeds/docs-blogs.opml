  <outline text="Paligo Blog"
           title="Paligo Blog"
           xmlUrl="https://paligo.net/feed"
           type="rss"
           htmlUrl="https://paligo.net/blog/"
           description="Company blog of the Paligo CCMS, providing technical communication professionals with expert guidance on creating efficient, scalable documentation systems.Topics include structured content (CCMS) workflows, information architecture, knowledge management, AI-ready documentation, and strategies to improve content quality.">
  </outline>
  
