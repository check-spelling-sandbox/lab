  </outline>
  
  <outline text="Everything Technical Writing"
           title="Everything Technical Writing"
           xmlUrl="https://www.everythingtechnicalwriting.com/rss"
           type="rss"
           htmlUrl="https://www.everythingtechnicalwriting.com"
           description="A one-stop blog for all things technical writing with tips, tricks, and techniques for thriving as a technical writer in software. Includes career guidance, expert interviews, and insights into open-source documentation.">
  </outline>
  
  <outline text="ffeathers"
           title="ffeathers"
           xmlUrl="https://ffeathers.wordpress.com/feed"
           type="rss"
